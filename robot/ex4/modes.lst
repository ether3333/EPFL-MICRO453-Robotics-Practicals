  10:modes.c       **** 
  11:modes.c       **** void motor_demo_mode()
  12:modes.c       **** {
  13:modes.c       ****   // Initialize controller and PD parameters
  14:modes.c       ****   init_body_module(MOTOR_ADDR);
  15:modes.c       ****   // Start the PD controller
  16:modes.c       ****   start_pid(MOTOR_ADDR);
  17:modes.c       ****   // Set the LED to red to show activity
  18:modes.c       ****   set_color(4);
  19:modes.c       ****   // Loop until we remain in demo mode
  20:modes.c       ****   while (reg8_table[REG8_MODE] == IMODE_MOTOR_DEMO) {
  21:modes.c       ****     bus_set(MOTOR_ADDR, MREG_SETPOINT, DEG_TO_OUTPUT_BODY(21.0));
  22:modes.c       ****     pause(HALF_SEC);
  23:modes.c       ****     bus_set(MOTOR_ADDR, MREG_SETPOINT, DEG_TO_OUTPUT_BODY(-21.0));
  24:modes.c       ****     pause(HALF_SEC);
  25:modes.c       ****   }
  26:modes.c       ****   // Send back the motor to zero position
  27:modes.c       ****   bus_set(MOTOR_ADDR, MREG_SETPOINT, DEG_TO_OUTPUT_BODY(0.0));
  28:modes.c       ****   // Give it some time for this to happen
  29:modes.c       ****   pause(HALF_SEC);
  30:modes.c       ****   // Turn off the PD controller
  31:modes.c       ****   bus_set(MOTOR_ADDR, MREG_MODE, MODE_IDLE);
  32:modes.c       ****   // Set back LED to green
  33:modes.c       ****   set_color(2);
  34:modes.c       **** }
